import pandas as pd
import numpy as np
from sklearn.metrics import mean_squared_error

y_train = pd.read_csv('y_train.csv')
y_test = pd.read_csv('y_test.csv')

base_value = y_train['Sales'].mean()
base_pre = np.full(len(y_test), base_value)
y_true = y_test['Sales'].values
base_mse = mean_squared_error(y_true, base_pre)
N = int(input())
for i in range(N):
    pre = [float(x) for x in input().split()]
    model_mse = mean_squared_error(y_true, pre)
    if model_mse <= base_mse:
        print(True)
    else:
        print(False)
